"""
Problem: sort an array of heights and return the number of indices that didn't match with the original unsorted array
Platform: Leetcode
Language: Python3
Difficulty: Easy
"""
class Solution:
    def heightChecker(self, heights: List[int]) -> int:
        expected = sorted(heights)
        count = 0
        for i in range(len(heights)):
            if expected[i] != heights[i]:
                count += 1
        return count
