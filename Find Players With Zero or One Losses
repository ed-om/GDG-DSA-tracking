	
"""
Problem: Find and return players with zero or one losses from players in a list called matches
Platform: Leetcode
Language: Python3
Difficulty: Easy
"""
class Solution:
    def findWinners(self, matches: List[List[int]]) -> List[List[int]]:
        loss_count = {}
        
        for winner, loser in matches:
            loss_count[winner] = loss_count.get(winner, 0)
            loss_count[loser] = loss_count.get(loser, 0) + 1
        
        zero_loss = []
        one_loss = []
        
        for player, losses in sorted(loss_count.items()):
            if losses == 0:
                zero_loss.append(player)
            elif losses == 1:
                one_loss.append(player)
        
        return [zero_loss, one_loss]
