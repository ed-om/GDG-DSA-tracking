"""
Problem: Find the starting and ending position of a given target value
Platform: LeetCode
Language: Python3
Difficulty: Easy
"""
class Solution:
    def searchRange(self, nums: List[int], target: int) -> List[int]:
        left, right = 0, len(nums) - 1
        result = [-1, -1]
        while left <= right:
            mid = left + (right - left) // 2
            if nums[mid] == target:
                result[0] = mid
                right = mid - 1
            elif nums[mid] < target:
                left = mid + 1
            else:
                right = mid - 1
        if result[0] == -1:
            return result
        left, right = result[0], len(nums) - 1
        while left <= right:
            mid = left + (right - left) // 2
            if nums[mid] == target:
                result[1] = mid
                left = mid + 1
            elif nums[mid] < target:
                left = mid + 1
            else:
                right = mid - 1
        
        return result
